[3.095157, "o", "\u001b[36m\u25c6\u001b[0m  Pick a model\r\n\u001b[36m\u2502\u001b[0m  \u001b[32m\u25cf\u001b[0m qwen-qwen3-235b-a22b-q3_k_m (Q3_K_M) \u001b[2m(70B+ Q3_K_M \u00b7 ~102.9 GiB (124.5 GiB VRAM) \u00b7 76 on whichllm)\u001b[0m\r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mqwen-qwen3.6-27b-q8_0 (Q8_0)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mgoogle-gemma-4-31b-it-q8_0 (Q8_0)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mminimaxai-minimax-m2.5-q3_k_m (Q3_K_M)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mqwen-qwen3-next-80b-a3b-instruct-q6_k (Q6_K)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mmistralai-mistral-large-instruct-2411-q5_k_m (Q5_K_M)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mopenai-gpt-oss-120b-q6_k (Q6_K)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mqwen-qwen3-30b-a3b-q6_k (Q6_K)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mqwen-qwq-32b-q8_0 (Q8_0)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mqwen-qwen3-next-80b-a3b-thinking-q6_k (Q6_K)\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mPaste an HF repo id\u2026\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mSkip \u2014 don't download a model\u001b[0m \r\n\u001b[36m\u2514  \u001b[0m\r\n"]
